<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#efe6dc"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textLength"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="65dp"
        android:text="Milyen hosszú szóra gondoljak?"
        android:textAlignment="center"
        android:textSize="18dp"/>

    <NumberPicker
        android:id="@+id/lengthNumberPicker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/textLength"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:ems="10"
        android:inputType="text"
        android:text="2 - 20"
        android:textAlignment="center"/>

    <TextView
        android:id="@+id/textDifficulty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@+id/lengthNumberPicker"
        android:layout_marginTop="60dp"
        android:text="Nehézségi szint"
        android:textAlignment="center"
        android:textSize="18dp"/>

    <Spinner
        android:id="@+id/difficultySpinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/textDifficulty"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"/>

    <Button
        android:id="@+id/start"
        android:layout_width="120dp"
        android:layout_height="80dp"
        android:layout_below="@+id/difficultySpinner"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"
        android:onClick="startGame"
        android:text="Indítás"
        android:textSize="20dp"/>

</RelativeLayout>